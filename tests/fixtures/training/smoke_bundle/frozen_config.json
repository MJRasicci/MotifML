{
  "seed": 17,
  "data_split": {
    "ratios": {
      "train": 0.5,
      "validation": 0.25,
      "test": 0.25
    },
    "hash_seed": 17,
    "grouping_strategy": "document_id",
    "grouping_key_fallback": "relative_path"
  },
  "model_input": {
    "projection_type": "sequence",
    "sequence_mode": "baseline_v1",
    "context_length": 64,
    "stride": 32,
    "padding_strategy": "right",
    "special_token_policy": {
      "bos": "document",
      "eos": "document",
      "padding_interaction": "outside_boundaries",
      "unknown_token_mapping": "map_to_unk"
    },
    "storage": {
      "backend": "parquet",
      "schema_version": "parquet-v1"
    },
    "reporting": {
      "worst_document_limit": 10,
      "oversized_token_count_threshold": 8192
    }
  },
  "model": {
    "architecture": "decoder_only_transformer",
    "context_length": 64,
    "dropout": 0.0,
    "embedding_dim": 32,
    "hidden_size": 64,
    "num_heads": 4,
    "num_layers": 1,
    "pad_token_id": 0,
    "positional_encoding": "learned",
    "vocabulary_size": 21
  },
  "training": {
    "device": "cpu",
    "batch_size": 2,
    "num_epochs": 1,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "gradient_clip_norm": 1.0,
    "optimizer": "adamw",
    "lr_scheduler": {
      "name": "constant",
      "warmup_steps": 0
    }
  },
  "evaluation": {
    "batch_size": 2,
    "decode_max_tokens": 4,
    "device": "cpu",
    "guardrails": {
      "maximum_generated_unk_rate": 0.5,
      "maximum_split_unk_rate": 0.5
    },
    "qualitative": {
      "prompt_token_count": 4,
      "samples_per_split": 1,
      "summary_token_limit": 3
    },
    "splits": [
      "validation"
    ],
    "top_k": 3
  }
}
