{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Motif Score",
  "description": "Schema for score.json inside a native .motif archive.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "artist": {
      "type": "string"
    },
    "album": {
      "type": "string"
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "instrument": {
            "type": "object",
            "properties": {
              "family": {
                "type": "integer"
              },
              "kind": {
                "type": "integer"
              },
              "role": {
                "type": "integer"
              }
            }
          },
          "transposition": {
            "type": "object",
            "properties": {
              "chromatic": {
                "type": "integer"
              },
              "octave": {
                "type": "integer"
              },
              "writtenMinusSoundingSemitones": {
                "type": "integer"
              }
            }
          },
          "staves": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "staffIndex": {
                  "type": "integer"
                },
                "tuning": {
                  "type": "object",
                  "properties": {
                    "pitches": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "label": {
                      "type": "string"
                    }
                  }
                },
                "capoFret": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "measures": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "index": {
                        "type": "integer"
                      },
                      "staffIndex": {
                        "type": "integer"
                      },
                      "clef": {
                        "type": "string"
                      },
                      "simileMark": {
                        "type": "string"
                      },
                      "voices": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "voiceIndex": {
                              "type": "integer"
                            },
                            "beats": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "integer"
                                  },
                                  "graceType": {
                                    "type": "string"
                                  },
                                  "slashed": {
                                    "type": "boolean"
                                  },
                                  "slapped": {
                                    "type": "boolean"
                                  },
                                  "popped": {
                                    "type": "boolean"
                                  },
                                  "palmMuted": {
                                    "type": "boolean"
                                  },
                                  "brush": {
                                    "type": "boolean"
                                  },
                                  "brushIsUp": {
                                    "type": "boolean"
                                  },
                                  "arpeggio": {
                                    "type": "boolean"
                                  },
                                  "rasgueado": {
                                    "type": "boolean"
                                  },
                                  "deadSlapped": {
                                    "type": "boolean"
                                  },
                                  "tremolo": {
                                    "type": "boolean"
                                  },
                                  "whammyBar": {
                                    "type": [
                                      "object",
                                      "null"
                                    ],
                                    "properties": {
                                      "enabled": {
                                        "type": "boolean"
                                      },
                                      "extended": {
                                        "type": "boolean"
                                      },
                                      "originValue": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "middleValue": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "destinationValue": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "originOffset": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "middleOffset1": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "middleOffset2": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      },
                                      "destinationOffset": {
                                        "type": [
                                          "number",
                                          "null"
                                        ]
                                      }
                                    }
                                  },
                                  "offset": {
                                    "type": "object",
                                    "properties": {
                                      "numerator": {
                                        "type": "integer"
                                      },
                                      "denominator": {
                                        "type": "integer"
                                      }
                                    },
                                    "required": [
                                      "numerator",
                                      "denominator"
                                    ]
                                  },
                                  "duration": {
                                    "type": "object",
                                    "properties": {
                                      "numerator": {
                                        "type": "integer"
                                      },
                                      "denominator": {
                                        "type": "integer"
                                      }
                                    },
                                    "required": [
                                      "numerator",
                                      "denominator"
                                    ]
                                  },
                                  "rhythm": {
                                    "type": [
                                      "object",
                                      "null"
                                    ],
                                    "properties": {
                                      "baseValue": {
                                        "enum": [
                                          "Unknown",
                                          "Whole",
                                          "Half",
                                          "Quarter",
                                          "Eighth",
                                          "Sixteenth",
                                          "ThirtySecond",
                                          "SixtyFourth",
                                          "OneHundredTwentyEighth",
                                          "TwoHundredFiftySixth"
                                        ]
                                      },
                                      "augmentationDots": {
                                        "type": "integer"
                                      },
                                      "primaryTuplet": {
                                        "type": [
                                          "object",
                                          "null"
                                        ],
                                        "properties": {
                                          "numerator": {
                                            "type": "integer"
                                          },
                                          "denominator": {
                                            "type": "integer"
                                          }
                                        }
                                      },
                                      "secondaryTuplet": {
                                        "type": [
                                          "object",
                                          "null"
                                        ],
                                        "properties": {
                                          "numerator": {
                                            "type": "integer"
                                          },
                                          "denominator": {
                                            "type": "integer"
                                          }
                                        }
                                      }
                                    }
                                  },
                                  "notes": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "id": {
                                          "type": "integer"
                                        },
                                        "velocity": {
                                          "type": [
                                            "integer",
                                            "null"
                                          ]
                                        },
                                        "pitch": {
                                          "type": [
                                            "object",
                                            "null"
                                          ],
                                          "properties": {
                                            "step": {
                                              "type": "string"
                                            },
                                            "accidental": {
                                              "type": "string"
                                            },
                                            "octave": {
                                              "type": "integer"
                                            }
                                          }
                                        },
                                        "showStringNumber": {
                                          "type": "boolean"
                                        },
                                        "stringNumber": {
                                          "type": [
                                            "integer",
                                            "null"
                                          ]
                                        },
                                        "duration": {
                                          "type": "object",
                                          "properties": {
                                            "numerator": {
                                              "type": "integer"
                                            },
                                            "denominator": {
                                              "type": "integer"
                                            }
                                          },
                                          "required": [
                                            "numerator",
                                            "denominator"
                                          ]
                                        },
                                        "soundingDuration": {
                                          "type": "object",
                                          "properties": {
                                            "numerator": {
                                              "type": "integer"
                                            },
                                            "denominator": {
                                              "type": "integer"
                                            }
                                          },
                                          "required": [
                                            "numerator",
                                            "denominator"
                                          ]
                                        },
                                        "articulation": {
                                          "type": "object",
                                          "properties": {
                                            "leftFingering": {
                                              "type": "string"
                                            },
                                            "rightFingering": {
                                              "type": "string"
                                            },
                                            "ornament": {
                                              "type": "string"
                                            },
                                            "letRing": {
                                              "type": "boolean"
                                            },
                                            "vibrato": {
                                              "type": "string"
                                            },
                                            "tieOrigin": {
                                              "type": "boolean"
                                            },
                                            "tieDestination": {
                                              "type": "boolean"
                                            },
                                            "trill": {
                                              "type": [
                                                "integer",
                                                "null"
                                              ]
                                            },
                                            "trillSpeed": {
                                              "type": "integer"
                                            },
                                            "accent": {
                                              "type": [
                                                "integer",
                                                "null"
                                              ]
                                            },
                                            "antiAccent": {
                                              "type": "boolean"
                                            },
                                            "palmMuted": {
                                              "type": "boolean"
                                            },
                                            "muted": {
                                              "type": "boolean"
                                            },
                                            "tapped": {
                                              "type": "boolean"
                                            },
                                            "leftHandTapped": {
                                              "type": "boolean"
                                            },
                                            "hopoOrigin": {
                                              "type": "boolean"
                                            },
                                            "hopoDestination": {
                                              "type": "boolean"
                                            },
                                            "hopoType": {
                                              "type": "integer"
                                            },
                                            "slides": {
                                              "type": "array",
                                              "items": {
                                                "type": "integer"
                                              }
                                            },
                                            "harmonic": {
                                              "type": [
                                                "object",
                                                "null"
                                              ],
                                              "properties": {
                                                "type": {
                                                  "type": [
                                                    "integer",
                                                    "null"
                                                  ]
                                                },
                                                "typeName": {
                                                  "type": "string"
                                                },
                                                "kind": {
                                                  "type": "integer"
                                                },
                                                "fret": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "enabled": {
                                                  "type": "boolean"
                                                }
                                              }
                                            },
                                            "bend": {
                                              "type": [
                                                "object",
                                                "null"
                                              ],
                                              "properties": {
                                                "enabled": {
                                                  "type": "boolean"
                                                },
                                                "type": {
                                                  "type": "integer"
                                                },
                                                "originOffset": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "originValue": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "middleOffset1": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "middleOffset2": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "middleValue": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "destinationOffset": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                },
                                                "destinationValue": {
                                                  "type": [
                                                    "number",
                                                    "null"
                                                  ]
                                                }
                                              }
                                            },
                                            "relations": {
                                              "type": "array",
                                              "items": {
                                                "type": "object",
                                                "properties": {
                                                  "kind": {
                                                    "enum": [
                                                      "Legato",
                                                      "HammerOn",
                                                      "PullOff",
                                                      "Slide",
                                                      "Tie"
                                                    ]
                                                  },
                                                  "targetNoteId": {
                                                    "type": "integer"
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      },
                      "beats": {
                        "type": "array",
                        "items": {
                          "$ref": "#/properties/tracks/items/properties/staves/items/properties/measures/items/properties/voices/items/properties/beats/items"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "timelineBars": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "index": {
            "type": "integer"
          },
          "timeSignature": {
            "type": "string"
          },
          "start": {
            "type": "object",
            "properties": {
              "numerator": {
                "type": "integer"
              },
              "denominator": {
                "type": "integer"
              }
            },
            "required": [
              "numerator",
              "denominator"
            ]
          },
          "duration": {
            "type": "object",
            "properties": {
              "numerator": {
                "type": "integer"
              },
              "denominator": {
                "type": "integer"
              }
            },
            "required": [
              "numerator",
              "denominator"
            ]
          },
          "doubleBar": {
            "type": "boolean"
          },
          "freeTime": {
            "type": "boolean"
          },
          "tripletFeel": {
            "type": "string"
          },
          "repeatStart": {
            "type": "boolean"
          },
          "repeatEnd": {
            "type": "boolean"
          },
          "repeatCount": {
            "type": "integer"
          },
          "alternateEndings": {
            "type": "string"
          },
          "sectionLetter": {
            "type": "string"
          },
          "sectionText": {
            "type": "string"
          },
          "jump": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "keyAccidentalCount": {
            "type": [
              "integer",
              "null"
            ]
          },
          "keyMode": {
            "type": "string"
          }
        }
      }
    },
    "pointControls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "enum": [
              "Tempo",
              "Dynamic",
              "Fermata"
            ]
          },
          "scope": {
            "enum": [
              "Score",
              "Track",
              "Staff",
              "Voice"
            ]
          },
          "trackId": {
            "type": [
              "integer",
              "null"
            ]
          },
          "staffIndex": {
            "type": [
              "integer",
              "null"
            ]
          },
          "voiceIndex": {
            "type": [
              "integer",
              "null"
            ]
          },
          "position": {
            "type": "object",
            "properties": {
              "barIndex": {
                "type": "integer"
              },
              "offset": {
                "type": "object",
                "properties": {
                  "numerator": {
                    "type": "integer"
                  },
                  "denominator": {
                    "type": "integer"
                  }
                },
                "required": [
                  "numerator",
                  "denominator"
                ]
              }
            }
          },
          "value": {
            "type": "string"
          },
          "numericValue": {
            "type": [
              "number",
              "null"
            ]
          },
          "placement": {
            "type": "string"
          },
          "length": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      }
    },
    "spanControls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "enum": [
              "Hairpin",
              "Ottava",
              "Legato"
            ]
          },
          "scope": {
            "enum": [
              "Score",
              "Track",
              "Staff",
              "Voice"
            ]
          },
          "trackId": {
            "type": [
              "integer",
              "null"
            ]
          },
          "staffIndex": {
            "type": [
              "integer",
              "null"
            ]
          },
          "voiceIndex": {
            "type": [
              "integer",
              "null"
            ]
          },
          "start": {
            "type": "object",
            "properties": {
              "barIndex": {
                "type": "integer"
              },
              "offset": {
                "$ref": "#/properties/pointControls/items/properties/position/properties/offset"
              }
            }
          },
          "end": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "barIndex": {
                "type": "integer"
              },
              "offset": {
                "$ref": "#/properties/pointControls/items/properties/position/properties/offset"
              }
            }
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "anacrusis": {
      "type": "boolean"
    },
    "playbackMasterBarSequence": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  }
}
